@model SW.Scheduler.Viewer.RunningViewModel
@{
    Layout   = null;
    var basePath = ViewBag.BasePath as string ?? "/scheduler-management";
    ViewBag.ShowStatus = false;
}

<div class="section-header" style="margin-bottom:1.5rem;">
    <h2 style="margin:0">⟳ Currently Running</h2>
    <button hx-get="@basePath/Running"
            hx-target="#sw-content"
            hx-swap="innerHTML"
            hx-indicator="#spin"
            style="width:auto;margin:0;">
        ↻ Refresh
        <span id="spin" class="htmx-indicator"> …</span>
    </button>
</div>

@await Html.PartialAsync("_ExecutionTable", Model.Running)

